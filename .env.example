# AI Job Matching Platform - Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB (required for production, optional for dev)
# For local: mongodb://localhost:27017/ai-job-dev
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/

# CORS (production): comma-separated allowed browser origins
# Example: https://your-vercel-app.vercel.app
FRONTEND_URL=

# JWT (generate a strong secret for production)
# Use: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI API Key (optional - system works without AI fallback)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Logging
LOG_LEVEL=info
